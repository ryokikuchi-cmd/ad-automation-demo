# DB（Supabase の接続文字列 / ローカルPostgres）
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres

# Meta Marketing API（システムユーザートークン推奨）
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0

# access_token 暗号化キー（Fernet。`python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"`で生成）
TOKEN_ENCRYPTION_KEY=

# Claude API（ビジュアル因果分析・コピー生成）
ANTHROPIC_API_KEY=

# 商談スプシ取込用 Googleサービスアカウント（JSONのパス or 内容）
GOOGLE_SERVICE_ACCOUNT_JSON=./config/service_account.json

# 通知（任意・既存ntfy設定を流用可）
NTFY_TOPIC=claude-ryo-a652e0a5b3b8
